    {
      "name": "03 - Login Usuario 1 (sesion)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"seed.user1.{{seedTag}}@trikitrueke.local\",\n  \"clave\": \"SeedPass123\"\n}"
        },
        "url": "{{baseUrl}}/api/auth/login"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const rawSetCookie = pm.response.headers.get('Set-Cookie') || '';",
              "const match = rawSetCookie.match(/JSESSIONID=([^;]+)/);",
              "if (match && match[1]) {",
              "  pm.environment.set('jsessionid', match[1]);",
              "} else {",
              "  console.warn('No se encontro JSESSIONID en Set-Cookie');",
              "}"
            ]
          }
        }
      ]
    },

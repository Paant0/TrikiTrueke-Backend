  "item": [
    {
      "name": "01 - Registrar Usuario 1",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"nombre\": \"Seed Usuario 1\",\n  \"email\": \"seed.user1.{{seedTag}}@trikitrueke.local\",\n  \"telefono\": \"300111{{seedTag}}\",\n  \"clave\": \"SeedPass123\"\n}"
        },
        "url": "{{baseUrl}}/usuarios"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 201', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "const json = pm.response.json();",
              "pm.environment.set('user1Id', json.data.id);"
            ]
          }
        }
      ]
    },
